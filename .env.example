# ============================
# Configuración general
# ============================
APP_ENV=development
LOG_LEVEL=INFO

# SQLite local para ejecutar sin instalar servidores de base de datos.
DATABASE_URL=sqlite:///data/database/bank_analytics.db

# Fuente CSV principal
BANK_CSV_PATH=data/raw/bank.csv

# API REST externa: World Bank Indicators API
WORLD_BANK_API_BASE_URL=https://api.worldbank.org/v2
WORLD_BANK_COUNTRY=PRT
WORLD_BANK_START_YEAR=2018
WORLD_BANK_END_YEAR=2024
WORLD_BANK_TIMEOUT_SECONDS=8
WORLD_BANK_MAX_RETRIES=3
WORLD_BANK_CACHE_PATH=data/cache/world_bank_indicators_cache.json

# API propia
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
